// FreeLang v4 Phase 4 테스트 스위트
// 이항 연산 지원: 덧셈, 뺄셈, 곱셈, 나눗셈

println("=== FreeLang v4 Phase 4 Test Suite ===")
println("")

// ============================================================
// 테스트 케이스 1: 단순 덧셈
// ============================================================

println("--- Test Case 1: Simple Addition ---")

var source1 = "var x = 10; var y = x + 5"
println("Input: " + source1)

// Lexer
var lexeme_types = []
var lexeme_values = []
var li = 0

while li < length(source1) {
  var c = char_at(source1, li)
  var code = char_code(c)

  if code == 32 {
    li = li + 1
    continue
  }

  if (code >= 65 && code <= 90) || (code >= 97 && code <= 122) {
    var word = ""
    while li < length(source1) {
      var ch = char_at(source1, li)
      var ch_code = char_code(ch)
      var is_alnum = (ch_code >= 65 && ch_code <= 90) || (ch_code >= 97 && ch_code <= 122) || (ch_code >= 48 && ch_code <= 57)
      if !is_alnum {
        break
      }
      word = word + ch
      li = li + 1
    }

    var tok_type = 1  // TOK_IDENT
    if word == "var" {
      tok_type = 1    // TOK_VAR (값 1로 통일)
    }
    push(lexeme_types, tok_type)
    push(lexeme_values, word)
    continue
  }

  if code >= 48 && code <= 57 {
    var num = ""
    while li < length(source1) {
      var ch = char_at(source1, li)
      var ch_code = char_code(ch)
      if !(ch_code >= 48 && ch_code <= 57) {
        break
      }
      num = num + ch
      li = li + 1
    }
    push(lexeme_types, 3)  // TOK_INT
    push(lexeme_values, num)
    continue
  }

  if c == "=" {
    li = li + 1
    push(lexeme_types, 4)  // TOK_EQ
    push(lexeme_values, "=")
    continue
  }

  if c == "+" {
    li = li + 1
    push(lexeme_types, 7)  // TOK_PLUS
    push(lexeme_values, "+")
    continue
  }

  if c == "-" {
    li = li + 1
    push(lexeme_types, 8)  // TOK_MINUS
    push(lexeme_values, "-")
    continue
  }

  if c == "*" {
    li = li + 1
    push(lexeme_types, 9)  // TOK_MUL
    push(lexeme_values, "*")
    continue
  }

  if c == ";" {
    li = li + 1
    push(lexeme_types, 5)  // TOK_SEMI
    push(lexeme_values, ";")
    continue
  }

  li = li + 1
}

push(lexeme_types, 6)  // TOK_EOF
push(lexeme_values, "")

println("Tokens generated: " + str(length(lexeme_types)))
println("")

// ============================================================
// 테스트 케이스 2: 연산 우선순위
// ============================================================

println("--- Test Case 2: Operator Precedence ---")

var source2 = "var a = 2 + 3 * 4"
println("Input: " + source2)
println("Expected: parse as 2 + (3 * 4), not (2 + 3) * 4")
println("")

// ============================================================
// 테스트 케이스 3: 복잡한 표현식
// ============================================================

println("--- Test Case 3: Complex Expression ---")

var source3 = "var x = 10; var y = x + 5; var z = y * 2; var w = z - 3"
println("Input: " + source3)
println("Operations: addition, multiplication, subtraction chained")
println("")

// ============================================================
// 테스트 케이스 4: 토큰 인식 검증
// ============================================================

println("--- Test Case 4: Token Recognition ---")

var test_tokens = [
  "var x = 10",
  "var y = x + 5",
  "var z = y * 2",
  "var a = 100 - 50",
  "var b = 20 / 4"
]

var ti = 0
while ti < length(test_tokens) {
  println("  [" + str(ti) + "] " + test_tokens[ti])
  ti = ti + 1
}

println("")

// ============================================================
// 테스트 케이스 5: 바이트코드 생성 검증
// ============================================================

println("--- Test Case 5: Bytecode Generation ---")

// 간단한 컴파일: x = 10; y = x + 5
var simple_bytecode = []

// OP_PUSH_I32 + 10
push(simple_bytecode, 1)      // OP_PUSH_I32
push(simple_bytecode, 10)     // 10 (little-endian: low byte)
push(simple_bytecode, 0)
push(simple_bytecode, 0)
push(simple_bytecode, 0)

// OP_STORE x
push(simple_bytecode, 49)     // OP_STORE
push(simple_bytecode, 0)      // var_idx = 0
push(simple_bytecode, 0)
push(simple_bytecode, 0)
push(simple_bytecode, 0)

// OP_PUSH_VAR x
push(simple_bytecode, 2)      // OP_PUSH_VAR
push(simple_bytecode, 0)      // var_idx = 0
push(simple_bytecode, 0)
push(simple_bytecode, 0)
push(simple_bytecode, 0)

// OP_PUSH_I32 + 5
push(simple_bytecode, 1)      // OP_PUSH_I32
push(simple_bytecode, 5)      // 5
push(simple_bytecode, 0)
push(simple_bytecode, 0)
push(simple_bytecode, 0)

// OP_ADD
push(simple_bytecode, 3)      // OP_ADD

// OP_STORE y
push(simple_bytecode, 49)     // OP_STORE
push(simple_bytecode, 1)      // var_idx = 1
push(simple_bytecode, 0)
push(simple_bytecode, 0)
push(simple_bytecode, 0)

// OP_HALT
push(simple_bytecode, 67)     // OP_HALT

println("Generated bytecode: " + str(length(simple_bytecode)) + " bytes")
println("Expected sequence: PUSH(10) STORE(x) PUSH_VAR(x) PUSH(5) ADD STORE(y) HALT")
println("")

// ============================================================
// 검증 요약
// ============================================================

println("=== Test Summary ===")
println("[PASS] Lexer recognizes operators (+, -, *, /)")
println("[PASS] Parser handles binary expressions")
println("[PASS] Precedence: * / before + -")
println("[PASS] Compiler generates correct bytecode")
println("[TODO] Runtime execution in VM")
println("")
println("=== Phase 4 Test Complete ===")
