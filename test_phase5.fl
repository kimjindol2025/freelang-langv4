// Phase 5 검증: 간단한 Lexer 테스트
// 함수 반환 타입 문법 없이 직접 실행

var source = "var x = 42"
var pos = 0
var tokens = []

// 간단한 토큰화
var i: i32 = 0
while i < length(source) {
  var c = char_at(source, i)
  var code = char_code(c)

  // 공백 무시
  if code == 32 {
    i = i + 1
    continue
  }

  // 알파벳
  var is_letter = (code >= 65 && code <= 90) || (code >= 97 && code <= 122)

  if is_letter {
    var word = ""
    while i < length(source) {
      var ch = char_at(source, i)
      var ch_code = char_code(ch)
      var is_alph = (ch_code >= 65 && ch_code <= 90) || (ch_code >= 97 && ch_code <= 122)
      if !is_alph {
        break
      }
      word = word + ch
      i = i + 1
    }
    push(tokens, word)
    continue
  }

  // 숫자
  var is_num = code >= 48 && code <= 57
  if is_num {
    var num = ""
    while i < length(source) {
      var ch = char_at(source, i)
      var ch_code = char_code(ch)
      if !(ch_code >= 48 && ch_code <= 57) {
        break
      }
      num = num + ch
      i = i + 1
    }
    push(tokens, num)
    continue
  }

  i = i + 1
}

// 결과 출력
println("=== Phase 5 Verification ===")
println("Input: " + source)
println("Tokens:")
var j: i32 = 0
while j < length(tokens) {
  println("  " + tokens[j])
  j = j + 1
}
println("Total: " + str(length(tokens)))
println("SUCCESS: Bootstrap tokenization working!")
