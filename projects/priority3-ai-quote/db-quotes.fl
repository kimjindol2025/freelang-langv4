// Priority 3: AI Quote/Contract Assistant - Week 1
// Database Module: SQLite 견적 저장 및 조회
// sql.js를 활용한 경량 데이터베이스

println("=" + repeat("=", 59))
println("Database Module - SQLite Quote Storage")
println("=" + repeat("=", 59))
println("")

type Quote = {
  id: str,
  customer_phone: str,
  car_info: Object,
  services: [Object],
  total_price: num,
  status: str,
  created_at: num,
  expires_at: num,
}

type DatabaseResult = {
  success: bool,
  data: any,
  error_message: str,
  affected_rows: num,
  query_time_ms: num,
}

// 데이터베이스 초기화
fn init_quotes_db() -> DatabaseResult {
  var start_time = time_millis()

  // 테이블 스키마
  var create_table_sql = "CREATE TABLE IF NOT EXISTS quotes (
    id TEXT PRIMARY KEY,
    customer_phone TEXT NOT NULL,
    car_info_json TEXT NOT NULL,
    services_json TEXT NOT NULL,
    total_price REAL NOT NULL,
    status TEXT DEFAULT 'active',
    created_at INTEGER NOT NULL,
    expires_at INTEGER NOT NULL,
    created_timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP
  )"

  match execute_sql(create_table_sql, []) {
    Ok(result) => {
      return {
        success: true,
        data: "quotes table initialized",
        error_message: "",
        affected_rows: 0,
        query_time_ms: time_millis() - start_time,
      }
    },
    Err(error) => {
      return {
        success: false,
        data: null,
        error_message: "Failed to initialize quotes table: " + error,
        affected_rows: 0,
        query_time_ms: time_millis() - start_time,
      }
    },
  }
}

// 견적 저장
fn save_quote(quote: Quote) -> DatabaseResult {
  var start_time = time_millis()

  var insert_sql = "INSERT INTO quotes (
    id,
    customer_phone,
    car_info_json,
    services_json,
    total_price,
    status,
    created_at,
    expires_at
  ) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"

  var params = [
    quote["id"],
    quote["customer_phone"],
    json_stringify(quote["car_info"]),
    json_stringify(quote["services"]),
    quote["total_price"],
    quote["status"],
    quote["created_at"],
    quote["expires_at"],
  ]

  match execute_sql(insert_sql, params) {
    Ok(result) => {
      return {
        success: true,
        data: {
          quote_id: quote["id"],
          saved_at: time_millis(),
        },
        error_message: "",
        affected_rows: 1,
        query_time_ms: time_millis() - start_time,
      }
    },
    Err(error) => {
      return {
        success: false,
        data: null,
        error_message: "Failed to save quote: " + error,
        affected_rows: 0,
        query_time_ms: time_millis() - start_time,
      }
    },
  }
}

// 견적 조회 (ID로)
fn get_quote_by_id(quote_id: str) -> DatabaseResult {
  var start_time = time_millis()

  var select_sql = "SELECT * FROM quotes WHERE id = ?"
  var params = [quote_id]

  match execute_sql_select(select_sql, params) {
    Ok(rows) => {
      if len(rows) == 0 {
        return {
          success: false,
          data: null,
          error_message: "Quote not found: " + quote_id,
          affected_rows: 0,
          query_time_ms: time_millis() - start_time,
        }
      }

      var row = rows[0]
      var quote = {
        id: row["id"],
        customer_phone: row["customer_phone"],
        car_info: json_parse(row["car_info_json"]) || {},
        services: json_parse(row["services_json"]) || [],
        total_price: row["total_price"],
        status: row["status"],
        created_at: row["created_at"],
        expires_at: row["expires_at"],
      }

      return {
        success: true,
        data: quote,
        error_message: "",
        affected_rows: 1,
        query_time_ms: time_millis() - start_time,
      }
    },
    Err(error) => {
      return {
        success: false,
        data: null,
        error_message: "Database query failed: " + error,
        affected_rows: 0,
        query_time_ms: time_millis() - start_time,
      }
    },
  }
}

// 고객 견적 조회 (전화번호로)
fn get_quotes_by_phone(phone_number: str) -> DatabaseResult {
  var start_time = time_millis()

  var select_sql = "SELECT * FROM quotes WHERE customer_phone = ? ORDER BY created_at DESC"
  var params = [phone_number]

  match execute_sql_select(select_sql, params) {
    Ok(rows) => {
      var quotes = []
      var i = 0
      while i < len(rows) {
        var row = rows[i]
        var quote = {
          id: row["id"],
          customer_phone: row["customer_phone"],
          car_info: json_parse(row["car_info_json"]) || {},
          services: json_parse(row["services_json"]) || [],
          total_price: row["total_price"],
          status: row["status"],
          created_at: row["created_at"],
          expires_at: row["expires_at"],
        }
        var_push(quotes, quote)
        i = i + 1
      }

      return {
        success: true,
        data: quotes,
        error_message: "",
        affected_rows: len(quotes),
        query_time_ms: time_millis() - start_time,
      }
    },
    Err(error) => {
      return {
        success: false,
        data: [],
        error_message: "Database query failed: " + error,
        affected_rows: 0,
        query_time_ms: time_millis() - start_time,
      }
    },
  }
}

// 견적 상태 업데이트
fn update_quote_status(quote_id: str, new_status: str) -> DatabaseResult {
  var start_time = time_millis()

  var update_sql = "UPDATE quotes SET status = ? WHERE id = ?"
  var params = [new_status, quote_id]

  match execute_sql(update_sql, params) {
    Ok(result) => {
      return {
        success: true,
        data: {
          quote_id: quote_id,
          new_status: new_status,
          updated_at: time_millis(),
        },
        error_message: "",
        affected_rows: 1,
        query_time_ms: time_millis() - start_time,
      }
    },
    Err(error) => {
      return {
        success: false,
        data: null,
        error_message: "Failed to update quote status: " + error,
        affected_rows: 0,
        query_time_ms: time_millis() - start_time,
      }
    },
  }
}

// 만료된 견적 조회
fn get_expired_quotes() -> DatabaseResult {
  var start_time = time_millis()
  var now = time_millis()

  var select_sql = "SELECT * FROM quotes WHERE expires_at < ? AND status = 'active'"
  var params = [now]

  match execute_sql_select(select_sql, params) {
    Ok(rows) => {
      var quotes = []
      var i = 0
      while i < len(rows) {
        var row = rows[i]
        var quote = {
          id: row["id"],
          customer_phone: row["customer_phone"],
          car_info: json_parse(row["car_info_json"]) || {},
          services: json_parse(row["services_json"]) || [],
          total_price: row["total_price"],
          status: row["status"],
          created_at: row["created_at"],
          expires_at: row["expires_at"],
        }
        var_push(quotes, quote)
        i = i + 1
      }

      return {
        success: true,
        data: quotes,
        error_message: "",
        affected_rows: len(quotes),
        query_time_ms: time_millis() - start_time,
      }
    },
    Err(error) => {
      return {
        success: false,
        data: [],
        error_message: "Database query failed: " + error,
        affected_rows: 0,
        query_time_ms: time_millis() - start_time,
      }
    },
  }
}

// 데이터베이스 통계 조회
fn get_database_stats() -> DatabaseResult {
  var start_time = time_millis()

  var stats_sql = "SELECT
    COUNT(*) as total_quotes,
    COUNT(CASE WHEN status = 'active' THEN 1 END) as active_quotes,
    COUNT(CASE WHEN status = 'accepted' THEN 1 END) as accepted_quotes,
    COUNT(CASE WHEN status = 'expired' THEN 1 END) as expired_quotes,
    SUM(total_price) as total_revenue
  FROM quotes"

  match execute_sql_select(stats_sql, []) {
    Ok(rows) => {
      if len(rows) == 0 {
        return {
          success: false,
          data: null,
          error_message: "No statistics available",
          affected_rows: 0,
          query_time_ms: time_millis() - start_time,
        }
      }

      var row = rows[0]
      var stats = {
        total_quotes: row["total_quotes"] || 0,
        active_quotes: row["active_quotes"] || 0,
        accepted_quotes: row["accepted_quotes"] || 0,
        expired_quotes: row["expired_quotes"] || 0,
        total_revenue: row["total_revenue"] || 0,
      }

      return {
        success: true,
        data: stats,
        error_message: "",
        affected_rows: 1,
        query_time_ms: time_millis() - start_time,
      }
    },
    Err(error) => {
      return {
        success: false,
        data: null,
        error_message: "Failed to fetch statistics: " + error,
        affected_rows: 0,
        query_time_ms: time_millis() - start_time,
      }
    },
  }
}

