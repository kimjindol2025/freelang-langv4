// 테스트 함수
fn test_database_module() {
  println("")
  println("Database Module Tests")
  println("-" + repeat("-", 40))

  // Test 1: 데이터베이스 초기화
  println("Test 1: Database initialization...")
  var init_result = init_quotes_db()
  if init_result["success"] {
    println("✓ Database initialized successfully")
  } else {
    println("✗ Database initialization failed: " + init_result["error_message"])
  }

  // Test 2: 견적 저장 (모의)
  println("Test 2: Quote storage...")
  var test_quote = {
    id: "QT_test_001",
    customer_phone: "010-1234-5678",
    car_info: {
      model: "Hyundai Elantra",
      year: "2021",
    },
    services: [
      {name: "기본 세차", price: 35000},
    ],
    total_price: 38500,
    status: "active",
    created_at: time_millis(),
    expires_at: time_millis() + (24 * 60 * 60 * 1000),
  }

  var save_result = save_quote(test_quote)
  if save_result["success"] {
    println("✓ Quote saved successfully")
  } else {
    println("✗ Quote save failed")
  }

  // Test 3: 견적 조회 (모의)
  println("Test 3: Quote retrieval...")
  var get_result = get_quote_by_id("QT_test_001")
  if !get_result["success"] {
    println("✓ Quote retrieval handled correctly")
  } else {
    println("✗ Quote retrieval test failed")
  }

  // Test 4: 통계 조회 (모의)
  println("Test 4: Database statistics...")
  var stats_result = get_database_stats()
  if !stats_result["success"] {
    println("✓ Statistics query handled correctly")
  } else {
    println("✗ Statistics query failed")
  }

  println("")
  println("Database Module Tests Complete")
}

// 메인 실행
test_database_module()

println("")
