fn num_to_str(n: num) -> str {
  var result = ""
  if n == 0 {
    return "0"
  }

  var num = n
  var digits = []
  while num > 0 {
    var digit = num % 10
    var_push(digits, digit)
    num = num / 10
  }

  var i = len(digits) - 1
  while i >= 0 {
    var c = digits[i]
    if c == 0 { result = result + "0" }
    else if c == 1 { result = result + "1" }
    else if c == 2 { result = result + "2" }
    else if c == 3 { result = result + "3" }
    else if c == 4 { result = result + "4" }
    else if c == 5 { result = result + "5" }
    else if c == 6 { result = result + "6" }
    else if c == 7 { result = result + "7" }
    else if c == 8 { result = result + "8" }
    else if c == 9 { result = result + "9" }
    i = i - 1
  }

  return result
}

fn num_to_str_decimal(n: num) -> str {
  // 간단한 구현
  return num_to_str(n)
}

fn format_currency(amount: num) -> str {
  return "₩" + num_to_str(amount as num)
}

fn format_timestamp(ts: num) -> str {
  return "T+" + num_to_str(ts)
}

