// Vision API 응답 타입 정의
type CarAnalysisResult = {
  success: bool,
  car_model: str,
  year: str,
  color: str,
  damage_areas: [str],
  damage_severity: str,      // "light", "moderate", "severe"
  confidence_score: num,      // 0.0 ~ 1.0
  analysis_notes: str,
  error_message: str,
  processing_time_ms: num,
}

// Vision API를 통한 차량 이미지 분석
fn analyze_car_image(image_base64: str) -> CarAnalysisResult {
  var start_time = time_millis()

  // 유효성 검사
  if !image_base64 || len(image_base64) == 0 {
    return {
      success: false,
      car_model: "",
      year: "",
      color: "",
      damage_areas: [],
      damage_severity: "",
      confidence_score: 0.0,
      analysis_notes: "",
      error_message: "Empty image data provided",
      processing_time_ms: time_millis() - start_time,
    }
  }

  // Claude Vision API 호출 프롬프트
  var prompt = "차량 이미지를 분석하고 다음 정보를 JSON 형식으로 반환하세요:
{
  \"car_model\": \"차량 모델명\",
  \"year\": \"제조연도\",
  \"color\": \"차량 색상\",
  \"damage_areas\": [\"손상 부위 1\", \"손상 부위 2\"],
  \"damage_severity\": \"light|moderate|severe\",
  \"confidence_score\": 0.95,
  \"analysis_notes\": \"상세 분석 내용\"
}"

  // HTTP POST 요청으로 Claude API 호출
  // Base URL은 환경 변수에서 로드
  var api_key = get_env("CLAUDE_API_KEY")

  if !api_key {
    return {
      success: false,
      car_model: "",
      year: "",
      color: "",
      damage_areas: [],
      damage_severity: "",
      confidence_score: 0.0,
      analysis_notes: "",
      error_message: "CLAUDE_API_KEY not configured",
      processing_time_ms: time_millis() - start_time,
    }
  }

  var headers = {
    "Content-Type": "application/json",
    "Authorization": "Bearer " + api_key,
    "anthropic-version": "2023-06-01",
  }

  var payload = {
    "model": "claude-3-5-sonnet-20241022",
    "max_tokens": 1024,
    "messages": [
      {
        "role": "user",
        "content": [
          {
            "type": "image",
            "source": {
              "type": "base64",
              "media_type": "image/jpeg",
              "data": image_base64,
            },
          },
          {
            "type": "text",
            "text": prompt,
          },
        ],
      },
    ],
  }

  // API 호출 (실제 HTTP POST 구현)
  var response = call_claude_vision_api(api_key, json_stringify(payload))

  // 응답 파싱
  match response {
    Ok(body) => {
      var result_json = json_parse(body)

      // 응답에서 분석 결과 추출
      var analysis = extract_vision_analysis(result_json)

      return {
        success: true,
        car_model: analysis["car_model"] || "",
        year: analysis["year"] || "",
        color: analysis["color"] || "",
        damage_areas: analysis["damage_areas"] || [],
        damage_severity: analysis["damage_severity"] || "",
        confidence_score: analysis["confidence_score"] || 0.0,
        analysis_notes: analysis["analysis_notes"] || "",
        error_message: "",
        processing_time_ms: time_millis() - start_time,
      }
    },
    Err(err_msg) => {
      return {
        success: false,
        car_model: "",
        year: "",
        color: "",
        damage_areas: [],
        damage_severity: "",
        confidence_score: 0.0,
        analysis_notes: "",
        error_message: err_msg,
        processing_time_ms: time_millis() - start_time,
      }
    },
  }
}

// Claude Vision API 호출 (HTTP 래퍼)
fn call_claude_vision_api(api_key: str, payload: str) -> Result<str, str> {
  var url = "https://api.anthropic.com/v1/messages"

  var headers = {
    "Content-Type": "application/json",
    "Authorization": "Bearer " + api_key,
    "anthropic-version": "2023-06-01",
  }

  match http_post_json(url, payload, headers) {
    Ok(response) => Ok(response),
    Err(error) => Err("Vision API call failed: " + error),
  }
}

// Vision API 응답 파싱
fn extract_vision_analysis(response: Object) -> Object {
  // API 응답 구조:
  // {
  //   "content": [{"type": "text", "text": "JSON 분석 결과"}],
  //   ...
  // }

  var result = {
    car_model: "",
    year: "",
    color: "",
    damage_areas: [],
    damage_severity: "",
    confidence_score: 0.0,
    analysis_notes: "",
  }

  if !response || !response["content"] {
    return result
  }

  var content = response["content"]
  if !is_array(content) || len(content) == 0 {
    return result
  }

  var text_content = content[0]
  if !text_content || text_content["type"] != "text" {
    return result
  }

  var text = text_content["text"]

  // JSON 추출 (마크다운 코드블록에서 JSON 추출)
  var json_text = extract_json_from_text(text)

  match json_parse(json_text) {
    Ok(parsed) => {
      result["car_model"] = parsed["car_model"] || ""
      result["year"] = parsed["year"] || ""
      result["color"] = parsed["color"] || ""
      result["damage_areas"] = parsed["damage_areas"] || []
      result["damage_severity"] = parsed["damage_severity"] || ""
      result["confidence_score"] = to_number(parsed["confidence_score"]) || 0.0
      result["analysis_notes"] = parsed["analysis_notes"] || ""
    },
    Err(_) => {
      // JSON 파싱 실패 - 기본값 반환
      result["analysis_notes"] = text
    },
  }

  return result
}

// 텍스트에서 JSON 객체 추출
fn extract_json_from_text(text: str) -> str {
  // 마크다운 코드블록 제거
  var json_text = text

  // ```json ... ``` 패턴 처리
  if contains(text, "```json") {
    var start = index_of(text, "```json") + 7
    var end = index_of(text, "```", start)
    if end > start {
      json_text = substring(text, start, end)
    }
  } else if contains(text, "```") {
    var start = index_of(text, "```") + 3
    var end = index_of(text, "```", start)
    if end > start {
      json_text = substring(text, start, end)
    }
  }

  // 공백 정리
  return trim(json_text)
}

// 문자열 포함 확인
fn contains(str: str, substr: str) -> bool {
  return index_of(str, substr) >= 0
}

// 부분 문자열 추출
fn substring(str: str, start: num, end: num) -> str {
  var result = ""
  var i = 0
  while i < len(str) {
    if i >= start && i < end {
      result = result + (str[i] || "")
    }
    i = i + 1
  }
  return result
}

// 인덱스 찾기
fn index_of(str: str, substr: str) -> num {
  var i = 0
  while i <= len(str) - len(substr) {
    var match = true
    var j = 0
    while j < len(substr) {
      if str[i + j] != substr[j] {
        match = false
      }
      j = j + 1
    }
    if match {
      return i
    }
    i = i + 1
  }
  return -1
}

// 공백 제거
fn trim(str: str) -> str {
  var start = 0
  var end = len(str) - 1

  while start <= end && is_whitespace(str[start]) {
    start = start + 1
  }

  while end >= start && is_whitespace(str[end]) {
    end = end - 1
  }

  if start > end {
    return ""
  }

  var result = ""
  var i = start
  while i <= end {
    result = result + str[i]
    i = i + 1
  }
  return result
}

// 공백 문자 확인
fn is_whitespace(c: str) -> bool {
  return c == " " || c == "\n" || c == "\t" || c == "\r"
}

// 테스트 함수
fn test_vision_engine() {
  println("")
  println("Vision Engine Tests")
  println("-" + repeat("-", 40))

  // Test 1: 빈 이미지 데이터 처리
  println("Test 1: Empty image handling...")
  var result1 = analyze_car_image("")
  if !result1["success"] {
    println("✓ Correctly rejected empty image")
  } else {
    println("✗ Failed: should reject empty image")
  }

  // Test 2: API 키 누락 처리
  println("Test 2: Missing API key handling...")
  if result1["error_message"] == "CLAUDE_API_KEY not configured" ||
     result1["error_message"] == "Empty image data provided" {
    println("✓ Correctly handled missing configuration")
  } else {
    println("✗ Failed: incorrect error handling")
  }

  println("")
  println("Vision Engine Tests Complete")
}

// 메인 실행
test_vision_engine()

println("")
println("Vision Engine initialization complete.")
println("Export: analyze_car_image/1")
