// 최소한의 부트스트랩 테스트 - 타입 문제 우회

println("=== FreeLang Bootstrap Test ===")

// 단순 배열 테스트 (타입 명시 없음)
var tokens = []
push(tokens, "var")
push(tokens, "x")
push(tokens, "42")

println("Simple tokens:")
var i = 0
while i < length(tokens) {
  println("  " + tokens[i])
  i = i + 1
}

// 숫자 처리 테스트
var source = "var x = 42"
var pos = 0
var num_str = ""

// "42" 부분 추출
pos = 8
while pos < length(source) {
  var ch = char_at(source, pos)
  var code = char_code(ch)
  if code >= 48 && code <= 57 {
    num_str = num_str + ch
  }
  pos = pos + 1
}

println("Number extracted: " + num_str)

// 숫자를 10진수로 변환
var num_val = 0
var vi = 0
while vi < length(num_str) {
  var digit_char = char_at(num_str, vi)
  var digit_code = char_code(digit_char)
  num_val = num_val * 10 + (digit_code - 48)
  vi = vi + 1
}

println("Number value: " + str(num_val))

// 4바이트 Little-endian 인코딩
println("Little-endian encoding of " + str(num_val) + ":")
var byte0 = bitand(num_val, 255)
var byte1 = bitand(shr(num_val, 8), 255)
var byte2 = bitand(shr(num_val, 16), 255)
var byte3 = bitand(shr(num_val, 24), 255)

println("  byte0: " + str(byte0))
println("  byte1: " + str(byte1))
println("  byte2: " + str(byte2))
println("  byte3: " + str(byte3))

// 바이트코드 배열 생성
var bytecode = []
push(bytecode, 1)      // OP_PUSH_I32
push(bytecode, byte0)
push(bytecode, byte1)
push(bytecode, byte2)
push(bytecode, byte3)
push(bytecode, 49)     // OP_STORE_GLOBAL
push(bytecode, 0)      // const index
push(bytecode, 0)
push(bytecode, 0)
push(bytecode, 0)
push(bytecode, 67)     // OP_HALT

println("Bytecode generated: " + str(length(bytecode)) + " bytes")
var bi = 0
while bi < length(bytecode) {
  println("  [" + str(bi) + "] " + str(bytecode[bi]))
  bi = bi + 1
}

println("")
println("SUCCESS: Bootstrap tokenization and compilation working!")
