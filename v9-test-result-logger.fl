// FreeLang v9 Result + Logger 통합 테스트 (v4 호환)

var test_passed: i32 = 0
var test_failed: i32 = 0

fn assert_true(name: str, value: bool) -> void {
    if value {
        println("  ✅ " + name)
        test_passed = test_passed + 1
    } else {
        println("  ❌ " + name)
        test_failed = test_failed + 1
    }
}

fn assert_eq(name: str, actual: str, expected: str) -> void {
    if actual == expected {
        println("  ✅ " + name)
        test_passed = test_passed + 1
    } else {
        println("  ❌ " + name)
        test_failed = test_failed + 1
    }
}

// ==================== Result 타입 구현 ====================

fn type_ok(value: str) -> str {
    "ok:" + value
}

fn type_err(error: str, code: str) -> str {
    "err:" + error + ":" + code
}

fn type_is_ok(r: str) -> bool {
    starts_with(r, "ok:")
}

fn type_is_err(r: str) -> bool {
    starts_with(r, "err:")
}

fn type_unwrap_or(r: str, default_val: str) -> str {
    var result = default_val
    if starts_with(r, "ok:") {
        // Extract value after "ok:" - skip first 3 characters
        result = substring_safe(r, 3)
    }
    result
}

// ==================== 간단한 검증 함수 ====================

fn validate_not_empty(value: str) -> str {
    var result = "ok:valid"
    if value == "" {
        result = "err:validation:empty"
    }
    result
}

fn validate_positive(value: str) -> str {
    var result = "ok:valid"
    if starts_with(value, "-") {
        result = "err:validation:negative"
    }
    result
}

// ==================== 유틸리티 함수 ====================

fn substring_safe(s: str, start: i32) -> str {
    // start 이후 모든 문자 추출
    var result = ""
    var i: i32 = start
    while i < length(s) {
        result = result + char_at(s, i)
        i = i + 1
    }
    result
}

// ==================== Logger 구현 ====================

fn logger_new() -> str {
    "logs:"
}

fn logger_log(log_str: str, message: str) -> str {
    log_str + "|" + message
}

fn logger_count(log_str: str) -> i32 {
    // Count pipes ("|")
    var count: i32 = 0
    var i: i32 = 0
    while i < length(log_str) {
        var ch = char_at(log_str, i)
        if ch == "|" {
            count = count + 1
        }
        i = i + 1
    }
    count
}

// ==================== Result 필드 테스트 ====================

fn test_result_fields() -> void {
    println("")
    println("🧪 테스트 1: Result 기본 동작")

    // type_ok
    var r_ok = type_ok("success")
    assert_true("type_ok 생성", starts_with(r_ok, "ok:"))
    assert_true("type_is_ok", type_is_ok(r_ok))
    assert_true("type_is_err 아님", !type_is_err(r_ok))

    // type_err
    var r_err = type_err("API 실패", "E_API")
    assert_true("type_err 생성", starts_with(r_err, "err:"))
    assert_true("type_is_err", type_is_err(r_err))
    assert_true("type_is_ok 아님", !type_is_ok(r_err))

    // unwrap_or - 성공
    var unwrapped = type_unwrap_or(r_ok, "default")
    assert_eq("unwrap_or (성공)", unwrapped, "success")

    // unwrap_or - 실패
    var unwrapped_err = type_unwrap_or(r_err, "fallback")
    assert_eq("unwrap_or (실패)", unwrapped_err, "fallback")
}

// ==================== 검증 함수 테스트 ====================

fn test_validation() -> void {
    println("")
    println("🧪 테스트 2: 검증 함수")

    // validate_not_empty - 비어있지 않음
    var v1 = validate_not_empty("hello")
    assert_true("validate_not_empty (성공)", starts_with(v1, "ok:"))

    // validate_not_empty - 비어있음
    var v2 = validate_not_empty("")
    assert_true("validate_not_empty (실패)", starts_with(v2, "err:"))

    // validate_positive - 양수
    var v3 = validate_positive("42")
    assert_true("validate_positive (성공)", starts_with(v3, "ok:"))

    // validate_positive - 음수
    var v4 = validate_positive("-5")
    assert_true("validate_positive (실패)", starts_with(v4, "err:"))
}

// ==================== Logger 테스트 ====================

fn test_logger() -> void {
    println("")
    println("🧪 테스트 3: Logger")

    var logger = logger_new()
    assert_eq("Logger 생성", logger, "logs:")

    logger = logger_log(logger, "Message 1")
    assert_true("로그 1개", logger_count(logger) == 1)

    logger = logger_log(logger, "Message 2")
    assert_true("로그 2개", logger_count(logger) == 2)

    logger = logger_log(logger, "Message 3")
    assert_true("로그 3개", logger_count(logger) == 3)
}

// ==================== 메인 ====================

fn main() -> void {
    println("╔═════════════════════════════════════════════════╗")
    println("║  v9 Result + Logger 통합 테스트 (v4 호환)       ║")
    println("╚═════════════════════════════════════════════════╝")

    test_result_fields()
    test_validation()
    test_logger()

    var total = test_passed + test_failed

    println("")
    println("═══════════════════════════════════════════════════")
    println("전체: " + str(test_passed) + " / " + str(total) + " 통과")
    println("═══════════════════════════════════════════════════")

    if test_failed == 0 {
        println("✅ v9 Result + Logger 테스트 완료!")
    } else {
        println("⚠️  " + str(test_failed) + "개 테스트 실패")
    }
}

main()
