// FreeLang v4 트레이트 예제

trait Drawable {
  fn draw(self) -> void;
}

struct Circle {
  radius: f64
}

impl Drawable for Circle {
  fn draw(self) -> void {
    println("Drawing a circle");
  }
}

struct Square {
  side: f64
}

impl Drawable for Square {
  fn draw(self) -> void {
    println("Drawing a square");
  }
}

// Main
let circle = Circle { radius: 5.0 };
circle.draw();

let square = Square { side: 10.0 };
square.draw();
