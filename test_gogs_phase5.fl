/// 캐시 테스트 1: 캐시 히트
fn test_cache_hit() -> TestResult {
    var start = now_ms()
    var name = "test_cache_hit"
    var test_pass = true
    var error_msg = ""

    // 동일한 API 호출 2번
    // 검증: 두 번째 호출이 캐시에서 반환되는지 확인
