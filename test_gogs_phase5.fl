// ============================================================================
// 6. 메인 테스트 실행 함수
// ============================================================================

/// 모든 테스트 실행
fn run_all_tests() -> TestSummary {
    println("========================================")
    println("gogs-cli Phase 5 통합 테스트 시작")
    println("========================================")
    println("")

    var results = []
    var total_start = now_ms()

    // CLI 명령어 테스트 (33개)
    println("[1/46] CLI 명령어 테스트 (33개)")
    results.push(test_auth_login())
    results.push(test_auth_status())
    results.push(test_repo_create())
    results.push(test_repo_list())
    results.push(test_repo_view())
    results.push(test_repo_delete())
    results.push(test_repo_ensure())
    results.push(test_user_create())
    results.push(test_user_list())
    results.push(test_user_view())
    results.push(test_user_delete())
    results.push(test_org_create())
    results.push(test_org_list())
    results.push(test_org_view())
    results.push(test_org_member_add())
    results.push(test_org_member_remove())
    results.push(test_team_create())
    results.push(test_team_list())
    results.push(test_issue_create())
    results.push(test_issue_list())
    results.push(test_webhook_create())
    results.push(test_webhook_list())
    results.push(test_webhook_delete())
    results.push(test_deploy_key_add())
    results.push(test_deploy_key_list())
    results.push(test_deploy_key_delete())
    results.push(test_batch_create())
    results.push(test_batch_ensure())
    results.push(test_batch_delete())
    results.push(test_config_set())
    results.push(test_config_get())
    results.push(test_analyze())
    results.push(test_version_and_help())

    // 에러 케이스 테스트 (5개)
    println("[2/46] 에러 케이스 테스트 (5개)")
    results.push(test_error_missing_args())
    results.push(test_error_invalid_flags())
    results.push(test_error_auth_failed())
    results.push(test_error_not_found())
    results.push(test_error_permission_denied())

    // 캐싱 성능 테스트 (3개)
    println("[3/46] 캐싱 성능 테스트 (3개)")
    results.push(test_cache_hit())
    results.push(test_cache_ttl_expiry())
    results.push(test_cache_api_reduction())

    // 배치 성능 테스트 (4개)
    println("[4/46] 배치 성능 테스트 (4개)")
    results.push(test_batch_1_worker())
    results.push(test_batch_4_workers())
    results.push(test_batch_10_workers())
    results.push(test_batch_20_workers())

    // API 서비스 통합 테스트 (7개)
    println("[5/46] API 서비스 통합 테스트 (7개)")
    results.push(test_api_repo_service())
    results.push(test_api_user_service())
    results.push(test_api_org_service())
    results.push(test_api_team_service())
    results.push(test_api_issue_service())
    results.push(test_api_webhook_service())
    results.push(test_api_deploy_key_service())

    // 결과 수집
    var passed = 0
    var failed = 0
    var skipped = 0

    var i: i32 = 0
    while i < length(results) {
        if results[i].passed {
            passed = passed + 1
        } else {
            failed = failed + 1
        }
        i = i + 1
    }

    var total_duration = now_ms() - total_start

    // 결과 출력
    println("")
    println("========================================")
    println("테스트 결과 요약")
    println("========================================")
    println("총 테스트: " + to_string(passed + failed))
    println("통과: " + to_string(passed))
    println("실패: " + to_string(failed))
    println("경과시간: " + to_string(total_duration) + "ms")
    println("")

    // 상세 결과
    println("상세 결과:")
    i = 0
    while i < length(results) {
        var result = results[i]
        var status = "PASS"
        if !result.passed {
            status = "FAIL"
        }

        println("  [" + status + "] " + result.name)
        if result.error != "" {
            println("       Error: " + result.error)
        }
        println("       Duration: " + to_string(result.duration_ms) + "ms")
        i = i + 1
    }

    println("")
    println("========================================")

    TestSummary {
        total: passed + failed,
        passed: passed,
        failed: failed,
        skipped: skipped,
        duration_ms: total_duration,
        results: results
    }
}

