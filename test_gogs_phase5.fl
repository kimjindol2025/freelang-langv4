// ============================================================================
// 8. 진입점
// ============================================================================

/// 메인 진입점
fn main() {
    var summary = run_all_tests()

    // 종료 코드
    if summary.failed > 0 {
        exit(1)
    } else {
        exit(0)
    }
}
