// FreeLang v9 컬렉션 테스트
// StringMap과 StringSet 구현 및 검증

// ==================== 테스트 프레임워크 ====================

struct TestCase {
    name: str
    passed: bool
    message: str
}

struct TestSuite {
    name: str
    tests: [TestCase]
    passed_count: i32
    failed_count: i32
}

fn test_case_new(name: str, passed: bool, message: str) -> TestCase {
    TestCase {
        name: name,
        passed: passed,
        message: message
    }
}

fn test_suite_new(name: str) -> TestSuite {
    TestSuite {
        name: name,
        tests: [],
        passed_count: 0,
        failed_count: 0
    }
}

fn test_suite_add(suite: TestSuite, test: TestCase) -> TestSuite {
    suite.tests.push(test)

    if test.passed {
        suite.passed_count = suite.passed_count + 1
        println("  ✅ " + test.name)
    } else {
        suite.failed_count = suite.failed_count + 1
        println("  ❌ " + test.name + ": " + test.message)
    }

    suite
}

fn test_suite_report(suite: TestSuite) -> str {
    var total = suite.passed_count + suite.failed_count
    var output = ""

    output = output + "╔════════════════════════════════════════════════╗\n"
    output = output + "║ " + suite.name + "\n"
    output = output + "╠════════════════════════════════════════════════╣\n"
    output = output + "║ Passed: " + str(suite.passed_count) + " / " + str(total) + "\n"
    output = output + "║ Failed: " + str(suite.failed_count) + " / " + str(total) + "\n"
    output = output + "╚════════════════════════════════════════════════╝\n"

    output
}

// ==================== StringMap 구현 ====================

struct StringMap {
    keys: [str]
    values: [str]
    size: i32
}

fn string_map_new() -> StringMap {
    StringMap {
        keys: [],
        values: [],
        size: 0
    }
}

fn string_map_set(m: StringMap, key: str, val: str) -> StringMap {
    // 기존 키 탐색
    var i: i32 = 0
    while i < length(m.keys) {
        if m.keys[i] == key {
            // 덮어쓰기
            m.values[i] = val
            return m
        }
        i = i + 1
    }

    // 새 키 추가
    m.keys.push(key)
    m.values.push(val)
    m.size = m.size + 1

    m
}

fn string_map_get(m: StringMap, key: str) -> str {
    var i: i32 = 0
    while i < length(m.keys) {
        if m.keys[i] == key {
            return m.values[i]
        }
        i = i + 1
    }

    ""  // 없으면 빈 문자열 반환
}

fn string_map_has(m: StringMap, key: str) -> bool {
    var i: i32 = 0
    while i < length(m.keys) {
        if m.keys[i] == key {
            return true
        }
        i = i + 1
    }

    false
}

fn string_map_remove(m: StringMap, key: str) -> StringMap {
    var new_keys: [str] = []
    var new_values: [str] = []
    var found: bool = false

    var i: i32 = 0
    while i < length(m.keys) {
        if m.keys[i] != key {
            new_keys.push(m.keys[i])
            new_values.push(m.values[i])
        } else {
            found = true
        }
        i = i + 1
    }

    if found {
        m.size = m.size - 1
    }

    m.keys = new_keys
    m.values = new_values

    m
}

// ==================== StringSet 구현 ====================

struct StringSet {
    items: [str]
    size: i32
}

fn string_set_new() -> StringSet {
    StringSet {
        items: [],
        size: 0
    }
}

fn string_set_add(s: StringSet, item: str) -> StringSet {
    // 중복 확인
    var i: i32 = 0
    while i < length(s.items) {
        if s.items[i] == item {
            return s  // 이미 있으면 그대로 반환
        }
        i = i + 1
    }

    // 새 항목 추가
    s.items.push(item)
    s.size = s.size + 1

    s
}

fn string_set_has(s: StringSet, item: str) -> bool {
    var i: i32 = 0
    while i < length(s.items) {
        if s.items[i] == item {
            return true
        }
        i = i + 1
    }

    false
}

fn string_set_remove(s: StringSet, item: str) -> StringSet {
    var new_items: [str] = []
    var found: bool = false

    var i: i32 = 0
    while i < length(s.items) {
        if s.items[i] != item {
            new_items.push(s.items[i])
        } else {
            found = true
        }
        i = i + 1
    }

    if found {
        s.size = s.size - 1
    }

    s.items = new_items

    s
}

// ==================== StringMap 테스트 ====================

fn test_string_map() -> TestSuite {
    var suite = test_suite_new("StringMap 테스트")

    // 생성
    var m = string_map_new()
    var t1 = test_case_new(
        "생성: 초기 크기=0",
        m.size == 0,
        "new map should have size 0"
    )
    suite = test_suite_add(suite, t1)

    // 추가
    m = string_map_set(m, "key1", "value1")
    var t2 = test_case_new(
        "추가: 크기 증가",
        m.size == 1,
        "size should be 1 after set"
    )
    suite = test_suite_add(suite, t2)

    // 조회
    var val = string_map_get(m, "key1")
    var t3 = test_case_new(
        "조회: 값 반환",
        val == "value1",
        "get should return stored value"
    )
    suite = test_suite_add(suite, t3)

    // 존재 확인
    var t4 = test_case_new(
        "has: 존재하는 키",
        string_map_has(m, "key1"),
        "has should return true for existing key"
    )
    suite = test_suite_add(suite, t4)

    // 미존재 키
    var t5 = test_case_new(
        "has: 없는 키",
        !string_map_has(m, "nonexistent"),
        "has should return false for missing key"
    )
    suite = test_suite_add(suite, t5)

    // 덮어쓰기
    m = string_map_set(m, "key1", "updated")
    var updated_val = string_map_get(m, "key1")
    var t6 = test_case_new(
        "덮어쓰기: 값 업데이트",
        updated_val == "updated",
        "set should overwrite existing key"
    )
    suite = test_suite_add(suite, t6)

    // 크기 불변 (덮어쓰기 후)
    var t7 = test_case_new(
        "덮어쓰기 후 크기 불변",
        m.size == 1,
        "size should remain 1 after overwrite"
    )
    suite = test_suite_add(suite, t7)

    // 여러 키 추가
    m = string_map_set(m, "key2", "value2")
    m = string_map_set(m, "key3", "value3")
    var t8 = test_case_new(
        "다중 키: 크기",
        m.size == 3,
        "size should be 3 with 3 keys"
    )
    suite = test_suite_add(suite, t8)

    // 제거
    m = string_map_remove(m, "key2")
    var t9 = test_case_new(
        "제거: 크기 감소",
        m.size == 2,
        "size should be 2 after removing key2"
    )
    suite = test_suite_add(suite, t9)

    // 제거 후 조회
    var removed_val = string_map_get(m, "key2")
    var t10 = test_case_new(
        "제거 후: 빈 문자열",
        removed_val == "",
        "get should return empty string for removed key"
    )
    suite = test_suite_add(suite, t10)

    suite
}

// ==================== StringSet 테스트 ====================

fn test_string_set() -> TestSuite {
    var suite = test_suite_new("StringSet 테스트")

    // 생성
    var s = string_set_new()
    var t1 = test_case_new(
        "생성: 초기 크기=0",
        s.size == 0,
        "new set should have size 0"
    )
    suite = test_suite_add(suite, t1)

    // 추가
    s = string_set_add(s, "item1")
    var t2 = test_case_new(
        "추가: 크기 증가",
        s.size == 1,
        "size should be 1 after add"
    )
    suite = test_suite_add(suite, t2)

    // 존재 확인
    var t3 = test_case_new(
        "has: 존재하는 항목",
        string_set_has(s, "item1"),
        "has should return true for existing item"
    )
    suite = test_suite_add(suite, t3)

    // 중복 추가 (크기 불변)
    s = string_set_add(s, "item1")
    var t4 = test_case_new(
        "중복 추가: 크기 불변",
        s.size == 1,
        "size should remain 1 for duplicate add"
    )
    suite = test_suite_add(suite, t4)

    // 다른 항목 추가
    s = string_set_add(s, "item2")
    s = string_set_add(s, "item3")
    var t5 = test_case_new(
        "다중 항목: 크기",
        s.size == 3,
        "size should be 3 with 3 items"
    )
    suite = test_suite_add(suite, t5)

    // 제거
    s = string_set_remove(s, "item2")
    var t6 = test_case_new(
        "제거: 크기 감소",
        s.size == 2,
        "size should be 2 after removing item2"
    )
    suite = test_suite_add(suite, t6)

    // 제거 후 존재 확인
    var t7 = test_case_new(
        "제거 후: 없는 항목",
        !string_set_has(s, "item2"),
        "has should return false for removed item"
    )
    suite = test_suite_add(suite, t7)

    suite
}

// ==================== 메인 ====================

fn main() {
    println("╔═════════════════════════════════════════════════╗")
    println("║  v9 컬렉션 테스트                               ║")
    println("╚═════════════════════════════════════════════════╝")
    println("")

    // StringMap 테스트
    println("🧪 테스트: StringMap")
    var suite1 = test_string_map()
    println(test_suite_report(suite1))

    // StringSet 테스트
    println("🧪 테스트: StringSet")
    var suite2 = test_string_set()
    println(test_suite_report(suite2))

    var total_passed = suite1.passed_count + suite2.passed_count
    var total_failed = suite1.failed_count + suite2.failed_count
    var total = total_passed + total_failed

    println("═══════════════════════════════════════════════════")
    println("전체: " + str(total_passed) + " / " + str(total) + " 통과")
    println("═══════════════════════════════════════════════════")
    println("")

    if total_failed == 0 {
        println("✅ v9 컬렉션 테스트 완료!")
    } else {
        println("⚠️  " + str(total_failed) + "개 테스트 실패")
    }
}
