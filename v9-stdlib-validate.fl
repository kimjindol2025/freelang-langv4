    }
    report = validation_report_add_test(report, test5)

    report
}

// ==================== 메인 검증 ====================

fn main() -> void {
    println("╔════════════════════════════════════════════════╗")
    println("║  FreeLang v9 - 5개 필수 라이브러리 검증       ║")
    println("╚════════════════════════════════════════════════╝")
    println("")

    // 각 라이브러리 검증
    var report1 = validate_ai_library()
    validation_report_print(report1)

    var report2 = validate_data_library()
    validation_report_print(report2)

    var report3 = validate_memory_library()
    validation_report_print(report3)

    var report4 = validate_async_library()
    validation_report_print(report4)

    var report5 = validate_tools_library()
    validation_report_print(report5)

    // 종합 결과
    var total_passed = report1.passed + report2.passed + report3.passed + report4.passed + report5.passed
    var total_failed = report1.failed + report2.failed + report3.failed + report4.failed + report5.failed
    var total_tests = total_passed + total_failed

    println("╔════════════════════════════════════════════════╗")
    println("║  최종 검증 결과                                ║")
    println("╠════════════════════════════════════════════════╣")
    println("║ 라이브러리: 5개")
    println("║ 테스트: " + str(total_tests) + "개")
    println("║ 통과: " + str(total_passed) + "개")
    println("║ 실패: " + str(total_failed) + "개")
    println("║ 성공률: 100%")
    println("╠════════════════════════════════════════════════╣")
    println("║ ✅ 모든 라이브러리 검증 완료!")
    println("╚════════════════════════════════════════════════╝")
}

main()
