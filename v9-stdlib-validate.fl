// FreeLang v9 표준 라이브러리 - 통합 검증
// 5개 라이브러리 모두 테스트

// ==================== 검증 프레임워크 ====================

struct ValidationTest {
    name: str,
    status: str,
    message: str
}

struct ValidationReport {
    library_name: str,
    tests: [ValidationTest],
    passed: i32,
    failed: i32
}

fn validation_report_new(lib_name: str) -> ValidationReport {
    ValidationReport {
        library_name: lib_name,
        tests: [],
        passed: 0,
        failed: 0
    }
}

fn validation_report_add_test(report: ValidationReport, test: ValidationTest) -> ValidationReport {
    report.tests.push(test)

    if test.status == "pass" {
        report.passed = report.passed + 1
        println("  ✅ " + test.name)
    } else {
        report.failed = report.failed + 1
        println("  ❌ " + test.name + ": " + test.message)
    }

    report
}

fn validation_report_print(report: ValidationReport) -> void {
    var total = report.passed + report.failed

    println("╔════════════════════════════════════════════════╗")
    println("║ " + report.library_name)
    println("╠════════════════════════════════════════════════╣")
    println("║ Passed: " + str(report.passed) + " / " + str(total))
    println("║ Failed: " + str(report.failed) + " / " + str(total))
    println("╚════════════════════════════════════════════════╝")
    println("")
}

// ==================== 라이브러리 1: AI/LLM 검증 ====================

fn validate_ai_library() -> ValidationReport {
    var report = validation_report_new("Library 1: AI/LLM")

    // Test 1: Result type_ok 검증
    var r_ok = type_ok("test_value")
    var test1_pass = type_is_ok(r_ok)
    var test1 = ValidationTest {
        name: "Result type_ok creation",
        status: if test1_pass { "pass" } else { "fail" },
        message: if test1_pass { "" } else { "type_ok failed" }
    }
    report = validation_report_add_test(report, test1)

    // Test 2: Result type_is_ok 검증
    var r_err = type_err("error message", "E_TEST")
    var test2_pass = !type_is_ok(r_err)
    var test2 = ValidationTest {
        name: "Result type_is_ok detection",
        status: if test2_pass { "pass" } else { "fail" },
        message: if test2_pass { "" } else { "type_is_ok detection failed" }
    }
    report = validation_report_add_test(report, test2)

    // Test 3: Result field access - value
    var test3_pass = r_ok.value == "test_value"
    var test3 = ValidationTest {
        name: "Result value field access",
        status: if test3_pass { "pass" } else { "fail" },
        message: if test3_pass { "" } else { "Expected value=test_value, got=" + r_ok.value }
    }
    report = validation_report_add_test(report, test3)

    // Test 4: Result field access - error_code
    var test4_pass = r_err.error_code == "E_TEST"
    var test4 = ValidationTest {
        name: "Result error_code field access",
        status: if test4_pass { "pass" } else { "fail" },
        message: if test4_pass { "" } else { "Expected error_code=E_TEST, got=" + r_err.error_code }
    }
    report = validation_report_add_test(report, test4)

    // Test 5: Result type_unwrap_or
    var unwrapped = type_unwrap_or(r_err, "default")
    var test5_pass = unwrapped == "default"
    var test5 = ValidationTest {
        name: "Result type_unwrap_or fallback",
        status: if test5_pass { "pass" } else { "fail" },
        message: if test5_pass { "" } else { "Expected default, got=" + unwrapped }
    }
    report = validation_report_add_test(report, test5)

    report
}

