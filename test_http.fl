// Test HTTP Client

// Test 1: Simple GET
var result1 = http_get("https://httpbin.org/get")
if is_ok(result1) {
  println("✓ GET 성공")
} else {
  println("❌ GET 실패")
}

// Test 2: Simple POST
var result2 = http_post("https://httpbin.org/post", "data=test")
if is_ok(result2) {
  println("✓ POST 성공")
} else {
  println("❌ POST 실패")
}

// Test 3: POST JSON
var json_body = json_stringify({})
var result3 = http_post_json("https://httpbin.org/post", json_body)
if is_ok(result3) {
  println("✓ POST JSON 성공")
} else {
  println("❌ POST JSON 실패")
}

println("모든 HTTP 테스트 완료")
